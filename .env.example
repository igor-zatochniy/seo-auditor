# Docker Compose template. Copy this file to `.env` and adjust values locally.

DB_USER=seo_user
DB_PASSWORD=change-me-locally
DB_NAME=seo_db
DB_HOST=postgres
DB_PORT=5432
WORKERS=3
HTTP_REQUEST_TIMEOUT=5s
ROBOTS_TIMEOUT=3s
DB_CONNECT_TIMEOUT=5s
DB_FETCH_TIMEOUT=5s
DB_WRITE_TIMEOUT=3s
MAX_HTML_BODY_BYTES=5242880
RATE_LIMIT_INTERVAL=500ms
ALLOW_PRIVATE_TARGETS=false

DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?sslmode=disable