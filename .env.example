# Docker Compose template. Copy this file to `.env` and adjust values locally.

DB_USER=seo_user
DB_PASSWORD=change-me-locally
DB_NAME=seo_db
DB_HOST=postgres
DB_PORT=5432
# Необов'язковий UUID запуску; порожнє значення генерується автоматично.
RUN_ID=
WORKERS=3
LOG_LEVEL=INFO
HTTP_REQUEST_TIMEOUT=5s
ROBOTS_TIMEOUT=3s
DB_CONNECT_TIMEOUT=5s
DB_FETCH_TIMEOUT=5s
DB_WRITE_TIMEOUT=3s
SHUTDOWN_TIMEOUT=25s
URL_BATCH_SIZE=100
MAX_HTML_BODY_BYTES=5242880
RATE_LIMIT_INTERVAL=500ms
MAX_CONCURRENT_PER_HOST=1
ROBOTS_CACHE_TTL=1h
ALLOW_PRIVATE_TARGETS=false
HTTP_MAX_RETRIES=2
DB_MAX_RETRIES=2
RETRY_BASE_DELAY=200ms
RETRY_MAX_DELAY=2s

DATABASE_URL=postgres://seo_user:change-me-locally@postgres:5432/seo_db?sslmode=disable
